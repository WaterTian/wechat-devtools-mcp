{
    "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
    "name": "io.github.WaterTian/wechat-devtools-mcp",
    "description": "MCP Server for WeChat DevTools CLI - Automate development & testing with 8 aggregated APIs.",
    "repository": {
        "url": "https://github.com/WaterTian/wechat-devtools-mcp",
        "source": "github"
    },
    "version": "0.9.1",
    "packages": [
        {
            "registryType": "pypi",
            "identifier": "wechat-devtools-mcp",
            "version": "0.9.1",
            "runtimeHint": "uvx",
            "transport": {
                "type": "stdio"
            },
            "environmentVariables": [
                {
                    "name": "WECHAT_DEVTOOLS_CLI",
                    "description": "微信开发者工具 CLI 路径，例如 C:\\Program Files (x86)\\Tencent\\微信web开发者工具\\cli.bat",
                    "isRequired": true,
                    "isSecret": false
                },
                {
                    "name": "WECHAT_PROJECT_PATH",
                    "description": "默认小程序项目绝对路径，例如 D:\\Projects\\MyMiniApp",
                    "isRequired": true,
                    "isSecret": false
                },
                {
                    "name": "WECHAT_CLI_TIMEOUT",
                    "description": "CLI 命令超时时间（秒）",
                    "isRequired": false,
                    "default": "30"
                },
                {
                    "name": "NODE_PATH",
                    "description": "Node.js 可执行文件路径",
                    "isRequired": false,
                    "default": "node"
                }
            ]
        }
    ]
}